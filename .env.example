# ----------------------------------------------------------------------------
# VeChain Thor mainnet resync — environment configuration
# Copy to .env and adjust before running `make resync-chain-setup`.
# ----------------------------------------------------------------------------

# Absolute path on the Linux host where Thor chain data will be stored.
# The directory must be writable by UID/GID 1000 (the container user).
# `make resync-chain-setup` will attempt to chown it automatically.
# Estimate ~200 GB of free space for a full mainnet resync.
HOST_THOR_DATA_DIR=/data/thor

# Grafana admin password (login at http://localhost:3000, user: admin).
GRAFANA_ADMIN_PASSWORD=admin

# Megabytes of RAM allocated to Thor's trie-node cache.
# Higher values speed up block processing. Default: 4096 (4 GB).
# Increase if the host has spare RAM (e.g. 8192 for an 16 GB machine).
THOR_CACHE=8192
