  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "content": "> **Resync note:** the X-axis reflects wall-clock replay time, not blockchain time. During a full mainnet resync Thor replays historical blocks faster than real-time, so call *rates* shown here are replay throughput rather than the original on-chain rate.",
        "mode": "markdown"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total ChainID Calls",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "sum(thor_metrics_vm_chainid_opcode_count)",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Delegate Calls",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "sum(thor_metrics_vm_chainid_opcode_count{call_type=\"delegate\"})",
          "legendFormat": "delegate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Delegate Call %",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 75 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "sum(thor_metrics_vm_chainid_opcode_count{call_type=\"delegate\"}) / sum(thor_metrics_vm_chainid_opcode_count) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ChainID Opcode Call Rate (calls / sec)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "calls/sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_vm_chainid_opcode_count{call_type=\"regular\"}[1m])",
          "legendFormat": "regular",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_vm_chainid_opcode_count{call_type=\"delegate\"}[1m])",
          "legendFormat": "delegate",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Call Stack Depth at CHAINID — Percentiles (P50 / P95 / P99)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "depth",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "none",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.50, rate(thor_metrics_vm_chainid_opcode_call_depth_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.95, rate(thor_metrics_vm_chainid_opcode_call_depth_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.99, rate(thor_metrics_vm_chainid_opcode_call_depth_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Call Stack Depth Distribution (cumulative snapshot)",
      "description": "Cumulative count of CHAINID calls by call-stack depth bucket. Each bar shows all calls at or below that depth.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "cumulative calls",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "barWidth": 0.9,
        "fillOpacity": 80,
        "gradientMode": "none",
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "auto",
        "tooltip": { "mode": "single", "sort": "none" },
        "xField": "le"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "sum by (le) (thor_metrics_vm_chainid_opcode_call_depth_bucket)",
          "legendFormat": "le={{le}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "le": "Depth ≤", "Value": "Calls" }
          }
        }
      ]
    }
  ],
