{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current Block",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "locale",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "thor_metrics_best_block_number",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Blockchain Date (synced up to)",
      "description": "The timestamp of the last processed block — shows what point in mainnet history is currently being replayed.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "dateTimeAsLocal",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "thor_metrics_best_block_timestamp * 1000",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Blocks / sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "ops",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_block_processed_count{type=\"received\",success=\"true\"}[1m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Estimated Time Remaining",
      "description": "Estimated as: remaining blocks ÷ current processing rate. Remaining blocks = (now − last block timestamp) ÷ 10 s.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "dtdurations",
          "mappings": [
            { "options": { "match": "null+nan", "result": { "text": "calculating…" } }, "type": "special" }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "(time() - thor_metrics_best_block_timestamp) / 10 / rate(thor_metrics_block_processed_count{type=\"received\",success=\"true\"}[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Sync Progress",
      "description": "Estimated progress based on block timestamps. Progress = synced blocks ÷ (synced + estimated remaining blocks).",
      "gridPos": { "h": 7, "w": 7, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "thor_metrics_best_block_number / (thor_metrics_best_block_number + (time() - thor_metrics_best_block_timestamp) / 10) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Block Processing Rate",
      "gridPos": { "h": 7, "w": 17, "x": 7, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "blocks/sec",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_block_processed_count{type=\"received\",success=\"true\"}[1m])",
          "legendFormat": "successful",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_block_processed_count{type=\"received\",success=\"false\"}[1m])",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Block Processing Duration — Percentiles (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.50, rate(thor_metrics_block_processed_duration_ms_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.95, rate(thor_metrics_block_processed_duration_ms_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "histogram_quantile(0.99, rate(thor_metrics_block_processed_duration_ms_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Transactions & Gas per Second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "gas/sec" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_block_processed_tx_count[1m])",
          "legendFormat": "tx/sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "rate(thor_metrics_block_processed_gas_counter[1m])",
          "legendFormat": "gas/sec",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Best Block Number over Time",
      "description": "Slope = sync speed. Steeper = faster replay.",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "axisLabel": "block number",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "locale"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "hidden", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-thor" },
          "expr": "thor_metrics_best_block_number",
          "legendFormat": "block",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["vechain", "thor", "resync"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "VeChain Thor – Resync Progression",
  "uid": "thor-resync-progress",
  "version": 1
}
